    "demo:raw": "node scripts/preflight-besu-runtime.mjs && node scripts/run-lending-demo.mjs",
    "demo:ui": "node scripts/run-besu-command.mjs demo:ui:raw",
    "deploy": "node scripts/run-besu-command.mjs deploy:raw",
    "seed": "node scripts/run-besu-command.mjs seed:raw",
    "demo": "node scripts/run-besu-command.mjs demo:raw",
    "besu:demo:ui": "npm run demo:ui",
    "besu:deploy": "npm run deploy",
    "besu:seed": "npm run seed",
    "besu:demo": "npm run demo",
    "besu:header": "node scripts/fetch-besu-header-update.mjs",
    "besu:verify-header": "node scripts/verify-besu-header-update.mjs",
    "verify:light-client:raw": "node scripts/verify-besu-light-client.mjs",
    "verify:light-client": "node scripts/run-besu-command.mjs verify:light-client:raw",
    "verify:storage-proof:raw": "node scripts/verify-besu-storage-proof.mjs",
    "verify:storage-proof": "node scripts/run-besu-command.mjs verify:storage-proof:raw",
    "verify:packet-relay:raw": "node scripts/verify-packet-relay.mjs",
    "verify:packet-relay": "node scripts/run-besu-command.mjs verify:packet-relay:raw",
    "verify:policy-packet:raw": "node scripts/verify-policy-packet-relay.mjs",
    "verify:policy-packet": "node scripts/run-besu-command.mjs verify:policy-packet:raw",
    "verify:timeout-height:raw": "node scripts/verify-packet-timeout-height.mjs",
    "verify:timeout-height": "node scripts/run-besu-command.mjs verify:timeout-height:raw",
    "verify:timeout-timestamp:raw": "node scripts/verify-packet-timeout-timestamp.mjs",
    "verify:timeout-timestamp": "node scripts/run-besu-command.mjs verify:timeout-timestamp:raw",
    "test:besu": "npm run verify:light-client && npm run verify:storage-proof && npm run verify:packet-relay && npm run verify:policy-packet && npm run verify:timeout-height && npm run verify:timeout-timestamp"
