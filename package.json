    "chai": "^4.3.7",
    "ethers": "^6.16.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.8",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0"
